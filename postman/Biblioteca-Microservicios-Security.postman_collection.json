	"item": [
		{
			"name": "1. Obtener Tokens",
			"description": "Obtener tokens JWT de Keycloak para los diferentes roles de usuario.",
			"item": [
				{
					"name": "Token LIBRARIAN (bibliotecario1)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Token obtenido exitosamente', function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.access_token).to.not.be.undefined;",
									"    pm.collectionVariables.set('token_librarian', jsonData.access_token);",
									"    console.log('Token LIBRARIAN guardado correctamente');",
									"});",
									"",
									"pm.test('Token contiene roles esperados', function () {",
									"    var jsonData = pm.response.json();",
									"    var token = jsonData.access_token;",
									"    var payload = JSON.parse(atob(token.split('.')[1]));",
									"    pm.expect(payload.realm_access.roles).to.include('ROLE_LIBRARIAN');",
									"    console.log('Roles:', payload.realm_access.roles);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{ "key": "grant_type", "value": "password" },
								{ "key": "client_id", "value": "{{circulacion_client_id}}" },
								{ "key": "client_secret", "value": "{{circulacion_client_secret}}" },
								{ "key": "username", "value": "bibliotecario1" },
								{ "key": "password", "value": "password123" }
							]
						},
						"url": {
							"raw": "{{token_url}}",
							"host": ["{{token_url}}"]
						},
						"description": "Obtiene un token JWT para el usuario bibliotecario1 con rol ROLE_LIBRARIAN + ROLE_USER."
					}
				},
